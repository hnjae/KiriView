{
  "id": "io.github.hnjae.KiriView",
  "runtime": "org.kde.Platform",
  "runtime-version": "6.10",
  "sdk": "org.kde.Sdk",
  "command": "kiriview",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable",
    "org.freedesktop.Sdk.Extension.llvm21"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin:/usr/lib/sdk/llvm21/bin"
  },
  "cleanup": ["/include", "/lib/cmake", "/lib/libvvdec.so", "/lib/pkgconfig"],
  "finish-args": [
    "--socket=wayland",
    "--device=dri",
    "--share=network",
    "--filesystem=home",
    "--filesystem=/media",
    "--filesystem=/mnt",
    "--filesystem=/run/media",
    "--filesystem=xdg-run/gvfs",
    "--talk-name=org.freedesktop.portal.Desktop",
    "--env=LIBHEIF_PLUGIN_PATH=/app/lib/libheif"
  ],
  "modules": [
    {
      "name": "vvdec",
      "buildsystem": "cmake-ninja",
      "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DCMAKE_INSTALL_LIBDIR=lib",
        "-DBUILD_SHARED_LIBS=ON",
        "-DVVDEC_ENABLE_LINK_TIME_OPT=OFF",
        "-DVVDEC_TOPLEVEL_OUTPUT_DIRS=OFF"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/fraunhoferhhi/vvdec.git",
          "tag": "v3.0.0",
          "commit": "31d0e257a1e21a0044ed19c7f7ce3f1e6609c4ca"
        }
      ]
    },
    {
      "name": "libheif",
      "buildsystem": "simple",
      "build-commands": [
        "cmake -S . -B build -G Ninja -DCMAKE_BUILD_TYPE=Release -DCMAKE_PREFIX_PATH=/app -DCMAKE_INSTALL_PREFIX=/app -DCMAKE_INSTALL_LIBDIR=lib -DENABLE_PLUGIN_LOADING=ON -DPLUGIN_DIRECTORY=/app/lib/libheif -DPLUGIN_INSTALL_DIRECTORY=/app/lib/libheif -DWITH_GDK_PIXBUF=OFF -DWITH_EXAMPLES=OFF -DBUILD_TESTING=OFF -DBUILD_DOCUMENTATION=OFF -DWITH_FFMPEG_DECODER=ON -DWITH_FFMPEG_DECODER_PLUGIN=ON -DWITH_VVDEC=ON -DWITH_VVDEC_PLUGIN=ON -DWITH_JPEG_DECODER=ON -DWITH_JPEG_ENCODER=ON -DWITH_OpenJPEG_DECODER=ON -DWITH_OpenJPEG_ENCODER=OFF -DWITH_DAV1D=ON -DWITH_DAV1D_PLUGIN=ON -DWITH_AOM_DECODER=OFF -DWITH_AOM_ENCODER=OFF -DWITH_OpenH264_DECODER=OFF -DWITH_LIBDE265=OFF -DWITH_X265=OFF -DWITH_KVAZAAR=OFF -DWITH_UVG266=OFF -DWITH_SvtEnc=OFF -DWITH_RAV1E=OFF -DWITH_OPENJPH_ENCODER=OFF -DWITH_VVENC=OFF -DWITH_UNCOMPRESSED_CODEC=OFF -DWITH_LIBSHARPYUV=OFF -DWITH_FUZZERS=OFF",
        "cmake --build build --parallel ${FLATPAK_BUILDER_N_JOBS:-$(nproc)}",
        "cmake --install build"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/strukturag/libheif.git",
          "tag": "v1.21.2",
          "commit": "62f1b8c76ed4d8305071fdacbe74ef9717bacac5"
        },
        {
          "type": "patch",
          "path": "flatpak/patches/libheif-ffmpeg-avc-decoder.patch"
        }
      ]
    },
    {
      "name": "kiriview",
      "buildsystem": "simple",
      "build-commands": [
        "cargo --offline build --release --jobs ${FLATPAK_BUILDER_N_JOBS:-$(nproc)}",
        "install -Dm755 target/release/kiriview /app/bin/kiriview",
        "install -Dm644 data/icons/hicolor/scalable/apps/io.github.hnjae.KiriView.svg /app/share/icons/hicolor/scalable/apps/io.github.hnjae.KiriView.svg",
        "scripts/install-translations.sh /app",
        "install -Dm644 target/i18n/io.github.hnjae.KiriView.desktop /app/share/applications/io.github.hnjae.KiriView.desktop"
      ],
      "run-tests": true,
      "test-rule": "",
      "test-commands": [
        "env CARGO_TARGET_DIR=target/flatpak LIBHEIF_PLUGIN_PATH=/app/lib/libheif cargo --offline test --all-targets --all-features --jobs ${FLATPAK_BUILDER_N_JOBS:-$(nproc)} -- --test-threads ${FLATPAK_BUILDER_N_JOBS:-$(nproc)}",
        "env LIBHEIF_PLUGIN_PATH=/app/lib/libheif cmake -S tests/cpp -B target/flatpak/cpp-tests -DCMAKE_BUILD_TYPE=Debug",
        "env LIBHEIF_PLUGIN_PATH=/app/lib/libheif cmake --build target/flatpak/cpp-tests --parallel ${FLATPAK_BUILDER_N_JOBS:-$(nproc)}",
        "env LIBHEIF_PLUGIN_PATH=/app/lib/libheif ctest --test-dir target/flatpak/cpp-tests --output-on-failure --parallel ${FLATPAK_BUILDER_N_JOBS:-$(nproc)}"
      ],
      "sources": [
        "cargo-sources.json",
        {
          "type": "dir",
          "path": ".",
          "skip": [".git", ".flatpak-builder", "build-dir", "repo", "target"]
        },
        {
          "type": "shell",
          "commands": [
            "mkdir -p .cargo",
            "cp -vf cargo/config .cargo/config.toml"
          ]
        }
      ]
    }
  ]
}
