{
  "id": "io.github.hnjae.KiriView",
  "runtime": "org.kde.Platform",
  "runtime-version": "6.10",
  "sdk": "org.kde.Sdk",
  "command": "kiriview",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable",
    "org.freedesktop.Sdk.Extension.llvm21"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin:/usr/lib/sdk/llvm21/bin"
  },
  "cleanup": [
    "/include",
    "/lib/cmake",
    "/lib/libopenh264.so",
    "/lib/libvvdec.so",
    "/lib/pkgconfig"
  ],
  "finish-args": [
    "--socket=wayland",
    "--device=dri",
    "--share=network",
    "--filesystem=home:ro",
    "--filesystem=/media:ro",
    "--filesystem=/mnt:ro",
    "--filesystem=/run/media:ro",
    "--filesystem=xdg-run/gvfs:ro",
    "--talk-name=org.freedesktop.portal.Desktop",
    "--env=LIBHEIF_PLUGIN_PATH=/app/lib/libheif:/usr/lib/x86_64-linux-gnu/codecs-extra/lib/libheif:/usr/lib/aarch64-linux-gnu/codecs-extra/lib/libheif"
  ],
  "modules": [
    {
      "name": "openh264",
      "buildsystem": "meson",
      "config-opts": ["--buildtype=release", "-Dtests=disabled"],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/cisco/openh264.git",
          "tag": "v2.6.0",
          "commit": "652bdb7719f30b52b08e506645a7322ff1b2cc6f"
        }
      ]
    },
    {
      "name": "vvdec",
      "buildsystem": "cmake-ninja",
      "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DCMAKE_INSTALL_LIBDIR=lib",
        "-DBUILD_SHARED_LIBS=ON",
        "-DVVDEC_ENABLE_LINK_TIME_OPT=OFF",
        "-DVVDEC_TOPLEVEL_OUTPUT_DIRS=OFF"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/fraunhoferhhi/vvdec.git",
          "tag": "v2.3.0",
          "commit": "edd47ab839a73e47d672b1f1ad071725eb955f93"
        }
      ]
    },
    {
      "name": "libheif-codec-plugins",
      "buildsystem": "simple",
      "build-commands": [
        "cmake -S . -B build -G Ninja -DCMAKE_BUILD_TYPE=Release -DCMAKE_PREFIX_PATH=/app -DCMAKE_INSTALL_PREFIX=/app -DCMAKE_INSTALL_LIBDIR=lib -DENABLE_PLUGIN_LOADING=ON -DPLUGIN_DIRECTORY=/app/lib/libheif -DPLUGIN_INSTALL_DIRECTORY=/app/lib/libheif -DWITH_GDK_PIXBUF=OFF -DWITH_OpenH264_DECODER=ON -DWITH_OpenH264_DECODER_PLUGIN=ON -DWITH_VVDEC=ON -DWITH_VVDEC_PLUGIN=ON -DWITH_FFMPEG_DECODER=ON -DWITH_FFMPEG_DECODER_PLUGIN=ON -DWITH_LIBDE265=OFF -DWITH_X265=OFF -DWITH_KVAZAAR=OFF -DWITH_UVG266=OFF -DWITH_AOM_DECODER=OFF -DWITH_AOM_ENCODER=OFF -DWITH_DAV1D=OFF -DWITH_SvtEnc=OFF -DWITH_RAV1E=OFF -DWITH_JPEG_DECODER=OFF -DWITH_JPEG_ENCODER=OFF -DWITH_OpenJPEG_DECODER=OFF -DWITH_OpenJPEG_ENCODER=OFF -DWITH_OPENJPH_ENCODER=OFF -DWITH_VVENC=OFF -DWITH_UNCOMPRESSED_CODEC=OFF -DWITH_LIBSHARPYUV=OFF -DWITH_EXAMPLES=OFF -DWITH_FUZZERS=OFF",
        "cmake --build build --target heif-openh264dec heif-vvdec heif-ffmpegdec",
        "install -Dm755 build/libheif/plugins/libheif-openh264dec.so /app/lib/libheif/libheif-openh264dec.so",
        "install -Dm755 build/libheif/plugins/libheif-vvdec.so /app/lib/libheif/libheif-vvdec.so",
        "install -Dm755 build/libheif/plugins/libheif-ffmpegdec.so /app/lib/libheif/libheif-ffmpegdec.so"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/strukturag/libheif.git",
          "tag": "v1.20.2",
          "commit": "35dad50a9145332a7bfdf1ff6aef6801fb613d68"
        },
        {
          "type": "patch",
          "path": "flatpak/patches/libheif-openh264-vflip.patch"
        },
        {
          "type": "patch",
          "path": "flatpak/patches/libheif-ffmpeg-avc-decoder.patch"
        }
      ]
    },
    {
      "name": "kiriview",
      "buildsystem": "simple",
      "build-commands": [
        "cargo --offline build --release",
        "install -Dm755 target/release/kiriview /app/bin/kiriview",
        "install -Dm644 data/icons/hicolor/scalable/apps/io.github.hnjae.KiriView.svg /app/share/icons/hicolor/scalable/apps/io.github.hnjae.KiriView.svg",
        "install -Dm644 io.github.hnjae.KiriView.desktop /app/share/applications/io.github.hnjae.KiriView.desktop"
      ],
      "run-tests": true,
      "test-rule": "",
      "test-commands": [
        "env CARGO_TARGET_DIR=target/flatpak cargo --offline test --all-targets --all-features",
        "cmake -S tests/cpp -B target/flatpak/cpp-tests -DCMAKE_BUILD_TYPE=Debug",
        "cmake --build target/flatpak/cpp-tests",
        "ctest --test-dir target/flatpak/cpp-tests --output-on-failure"
      ],
      "sources": [
        "cargo-sources.json",
        {
          "type": "dir",
          "path": ".",
          "skip": [".git", ".flatpak-builder", "build-dir", "repo", "target"]
        },
        {
          "type": "shell",
          "commands": [
            "mkdir -p .cargo",
            "cp -vf cargo/config .cargo/config.toml"
          ]
        }
      ]
    }
  ]
}
