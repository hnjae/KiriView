#
# KiriView Flatpak packaging patch.
#
# libheif 1.21.2 has upstream FFmpeg AVC support. Keep this downstream patch
# to prefer FFmpeg for AVC so AVC HEIF still images with auxiliary alpha keep
# using the decoder path that handles KiriView's AVC alpha samples reliably.

diff --git a/libheif/plugins/decoder_ffmpeg.cc b/libheif/plugins/decoder_ffmpeg.cc
index 73a3b75..c33ee17 100644
--- a/libheif/plugins/decoder_ffmpeg.cc
+++ b/libheif/plugins/decoder_ffmpeg.cc
@@ -70,6 +70,7 @@ struct ffmpeg_decoder
 };
 
 static const int FFMPEG_DECODER_PLUGIN_PRIORITY = 90;
+static const int FFMPEG_AVC_DECODER_PLUGIN_PRIORITY = 110;
 
 #define MAX_PLUGIN_NAME_LENGTH 80
 
@@ -105,7 +106,7 @@ static int ffmpeg_does_support_format(heif_compression_format format)
     return FFMPEG_DECODER_PLUGIN_PRIORITY;
   }
   else if (format == heif_compression_AVC) {
-    return FFMPEG_DECODER_PLUGIN_PRIORITY;
+    return FFMPEG_AVC_DECODER_PLUGIN_PRIORITY;
   }
 #if 0
   else if (format == heif_compression_VVC) {
