 static struct heif_error ffmpeg_v1_push_data(void *decoder_raw, const void *data, size_t size)
 {

   struct ffmpeg_decoder* decoder = (struct ffmpeg_decoder*) decoder_raw;

   const uint8_t* cdata = (const uint8_t*) data;

-  return decoder->nalMap.parseHevcNalu(cdata, size);
+  decoder->annexBData.clear();
+  decoder->codecId = AV_CODEC_ID_NONE;
+
+  size_t idx = 0;
+  while (idx < size) {
+    if (size - idx < 4) {
+      return {heif_error_Decoder_plugin_error,
+              heif_suberror_End_of_data,
+              "Unexpected end of NAL unit data"};
+    }
+
+    const uint32_t nalSize = ((cdata[idx] << 24) | (cdata[idx + 1] << 16) | (cdata[idx + 2] << 8) | cdata[idx + 3]);
+    idx += 4;
+
+    if (nalSize == 0 || size - idx < nalSize) {
+      return {heif_error_Decoder_plugin_error,
+              heif_suberror_End_of_data,
+              "Unexpected end of NAL unit data"};
+    }
+
+    const uint8_t* nal = cdata + idx;
+    const uint8_t h264Type = nal[0] & 0x1F;
+    const uint8_t hevcType = (nal[0] >> 1) & 0x3F;
+
+    if (decoder->codecId == AV_CODEC_ID_NONE) {
+      if (h264Type == 5 || h264Type == 6 || h264Type == 7 || h264Type == 8) {
+        decoder->codecId = AV_CODEC_ID_H264;
+      }
+      else if (hevcType == NAL_UNIT_VPS_NUT || hevcType == NAL_UNIT_SPS_NUT ||
+               hevcType == NAL_UNIT_PPS_NUT || hevcType == NAL_UNIT_IDR_W_RADL ||
+               hevcType == NAL_UNIT_IDR_N_LP) {
+        decoder->codecId = AV_CODEC_ID_HEVC;
+      }
+    }
+
+    decoder->annexBData.push_back(0);
+    decoder->annexBData.push_back(0);
+    decoder->annexBData.push_back(0);
+    decoder->annexBData.push_back(1);
+    decoder->annexBData.insert(decoder->annexBData.end(), nal, nal + nalSize);
+    idx += nalSize;
+  }
+
+  if (decoder->codecId == AV_CODEC_ID_NONE) {
+    return {heif_error_Decoder_plugin_error,
+            heif_suberror_Unspecified,
+            "Unsupported AVC/HEVC NAL unit data"};
+  }
+
+  return heif_error_success;
 }



