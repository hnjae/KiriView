#!/usr/bin/env bash
# SPDX-FileCopyrightText: 2026 KIM Hyunjae
# SPDX-License-Identifier: AGPL-3.0-or-later

set -euo pipefail

script_dir=$(CDPATH='' cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
repo_root=$(CDPATH='' cd -- "$script_dir/.." && pwd)
mode="${1:-all}"

case "$mode" in
    all | clang-tidy | clazy) ;;
    *)
        echo "usage: $0 [all|clang-tidy|clazy]" >&2
        exit 2
        ;;
esac

cd "$repo_root"
"$script_dir/refresh-cxxqt-includes"

if [[ ! -f compile_commands.json ]]; then
    echo "compile_commands.json was not found; enter the devenv shell to generate it" >&2
    exit 1
fi

if ! command -v jq >/dev/null; then
    echo "jq was not found in PATH" >&2
    exit 127
fi

mapfile -t sources < <(jq -r '.[].file' compile_commands.json)

if ((${#sources[@]} == 0)); then
    echo "compile_commands.json does not contain any C++ sources" >&2
    exit 1
fi

run_clang_tidy() {
    if ! command -v clang-tidy >/dev/null; then
        echo "clang-tidy was not found in PATH" >&2
        exit 127
    fi

    clang-tidy --quiet -p . "${sources[@]}"
}

run_clazy() {
    if ! command -v clazy-standalone >/dev/null; then
        echo "clazy-standalone was not found in PATH" >&2
        exit 127
    fi

    clazy-standalone --checks="${CLAZY_CHECKS:-level0}" -p . "${sources[@]}"
}

case "$mode" in
    all)
        run_clang_tidy
        run_clazy
        ;;
    clang-tidy)
        run_clang_tidy
        ;;
    clazy)
        run_clazy
        ;;
esac
